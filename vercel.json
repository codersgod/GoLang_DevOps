{
  "version": 2,
  "builds": [
    {
      "src": "api/index.go",
      "use": "@vercel/go"
    },
    {
      "src": "web/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(cost|ec2|services|security|security-details)$",
      "dest": "api/index.go"
    },
    {
      "src": "^/$",
      "dest": "/web/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/web/index.html"
    }
  ]
}
